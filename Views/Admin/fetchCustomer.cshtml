@model List<Customer>
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Customer</h2>

    <form method="get" class="row g-2 mt-3">
        <div class="col-md-4">
            <input type="text" name="searchTerm" class="form-control" placeholder="Tìm kiếm tên, email, điện thoại..." value="@(ViewContext.HttpContext.Request.Query["searchTerm"].ToString())" />
        </div>
        <div class="col-md-3">
            <select name="sortBy" class="form-select">
                <option value="">Sắp xếp</option>
                <option value="name" selected="@(ViewContext.HttpContext.Request.Query["sortBy"] == "name")">Tên</option>
                <option value="orders" selected="@(ViewContext.HttpContext.Request.Query["sortBy"] == "orders")">Số đơn</option>
                <option value="date" selected="@(ViewContext.HttpContext.Request.Query["sortBy"] == "date")">Ngày đăng ký</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="fromDate" class="form-control" value="@(ViewContext.HttpContext.Request.Query["fromDate"].ToString())" />
        </div>
        <div class="col-md-2">
            <input type="date" name="toDate" class="form-control" value="@(ViewContext.HttpContext.Request.Query["toDate"].ToString())" />
        </div>
        <div class="col-md-1">
            <button class="btn btn-primary w-100">Tìm</button>
        </div>
    </form>
</div>
<div class="row">
    <div class="col-md-12">
        <table class="table table-bordered table-striped text-center mt-3">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Customer Phone</th>
                    <th>Customer Country</th>
                    <th>Customer City</th>
                    <th>Customer Address</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var cust in Model)
                {
                    <tr>
                        <td>@cust.customer_name</td>
                        <td>@cust.customer_phone</td>
                        <td>@cust.customer_country</td>
                        <td>@cust.customer_city</td>
                        <td>@cust.customer_address</td>
                        <td>
                            <a href="@Url.Action("customerDetails","Admin", new{id=cust.customer_id})" class="btn btn-primary">Details</a>
                            <a href="@Url.Action("updateCustomer","Admin", new{id=cust.customer_id})" class="btn btn-warning">Update</a>
                            <a href="@Url.Action("deletePermission","Admin", new{id=cust.customer_id})" class="btn btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
