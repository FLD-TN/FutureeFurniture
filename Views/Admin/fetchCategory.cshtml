@model List<Category>
<div class="container-fluid px-4">
    <h2 class="mt-4 text-center text-uppercase" style="letter-spacing:4px">All Category</h2>
</div>
<div class="row">
    <div class="col-md-12">
        <form method="get" class="row g-2 mb-3">
                <div class="col-md-4">
                <input type="text" name="searchTerm" class="form-control" placeholder="Tìm kiếm tên danh mục..." value="@(ViewContext.HttpContext.Request.Query["searchTerm"].ToString())" />
            </div>
            <div class="col-md-3">
                <select name="sortBy" class="form-select">
                    <option value="">Sắp xếp</option>
                    <option value="name" selected="@(ViewContext.HttpContext.Request.Query["sortBy"] == "name")">Tên</option>
                    <option value="products" selected="@(ViewContext.HttpContext.Request.Query["sortBy"] == "products")">Số sản phẩm</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary">Tìm</button>
            </div>
        </form>
        <a href="@Url.Action("addCategory","Admin")" class="btn btn-primary">Add New Category</a>
        <table class="table table-bordered table-striped text-center mt-3">
            <thead>
                <tr>
                    <th>Category Id</th>
                    <th>Category Name</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var cat in Model)
                {
                    <tr>
                        <td>@cat.category_id</td>
                        <td>@cat.category_name</td>
                        <td>
                            <a href="@Url.Action("updateCategory","Admin", new{id=cat.category_id})" class="btn btn-primary">Update</a>
                            <a href="@Url.Action("deletePermissionCategory","Admin", new{id=cat.category_id})" class="btn btn-warning">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
